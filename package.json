{
  "name": "eslint-plugin-fast-import",
  "version": "2.2.1",
  "description": "ESLint/Oxlint plugin with rules to ensure proper semantic usage of imports and exports",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "oxlint",
    "oxlint-plugin"
  ],
  "homepage": "https://github.com/nebrius/eslint-plugin-fast-import",
  "bugs": "https://github.com/nebrius/eslint-plugin-fast-import/issues",
  "license": "MIT",
  "author": "Bryan Hughes <bryan@nebri.us>",
  "repository": {
    "type": "git",
    "url": "https://github.com/nebrius/eslint-plugin-fast-import.git"
  },
  "type": "module",
  "main": "dist/plugin.js",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "scripts": {
    "lint": "npm run lint:eslint && npm run lint:oxlint",
    "lint:eslint": "TIMING=1 eslint --report-unused-disable-directives \"**/*.{ts,tsx,mts,js,jsx,mjs}\"",
    "lint:eslint:fix": "eslint --fix \"**/*.{js,jsx,mjs,ts,tsx,mts}\"",
    "lint:oxlint": "oxlint --type-aware",
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage src",
    "format": "prettier --write A\"**/*.{js,jsx,mjs,ts,tsx,mts}\"",
    "publish-package": "node --experimental-strip-types scripts/publish.ts"
  },
  "dependencies": {
    "@manypkg/get-packages": "3.1.0",
    "@typescript-eslint/typescript-estree": "^8.29.1",
    "@typescript-eslint/utils": "^8.19.1",
    "cross-dirname": "^0.1.0",
    "ignore": "^7.0.3",
    "jsonc-parser": "3.3.1",
    "oxc-parser": "^0.106.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.24.0",
    "@jest/globals": "^30.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.0",
    "@typescript-eslint/parser": "^8.30.1",
    "@typescript-eslint/rule-tester": "^8.29.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.3.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-import-x": "^4.10.5",
    "eslint-plugin-jest": "^29.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "fast-deep-equal": "^3.1.3",
    "global": "^4.4.0",
    "globals": "^17.0.0",
    "jest-diff": "^30.0.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "prettier": "^3.8.3",
    "simple-git": "^3.27.0",
    "ts-jest": "^29.2.5",
    "ts-jest-resolver": "^2.0.1",
    "ts-node": "^10.9.2",
    "type-fest": "^5.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.29.1"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  }
}